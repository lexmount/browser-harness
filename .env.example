# Copy to .env — auto-loaded. Only needed for remote/cloud browsers.

# Browser Use cloud
BROWSER_USE_API_KEY=bu_your_key_here

# Lexmount cloud browser (used by bh-lex). Default region:
LEXMOUNT_API_KEY=your_key_here
LEXMOUNT_PROJECT_ID=your_project_id
LEXMOUNT_BASE_URL=https://api.lexmount.cn

# Optional second region, selected with BH_LEX_REGION=en
LEXMOUNT_API_KEY_EN=your_en_key_here
LEXMOUNT_PROJECT_ID_EN=your_en_project_id
LEXMOUNT_BASE_URL_EN=https://api.lexmount.com

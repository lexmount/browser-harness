#!/usr/bin/env python3
"""bh-lex — run browser-harness against a Lexmount cloud browser via the SDK.

Default browser for skill exploration. Two modes, both driven by the official
`lexmount` Python SDK / connection endpoint (see lexmount-python-sdk-quickstart):

  1. Connectionless (default): connect to the project's pooled cloud browser via
     wss://<host>/connection?project_id=&api_key= — no session to create, close,
     or leak. State (tabs/cookies) persists across calls. One browser per project,
     so this is for serial/interactive exploration.

  2. Isolated (BH_LEX_ISOLATED=1): create a dedicated ephemeral session per BU_NAME
     via sessions.create() for parallel work; reused across calls, closed with
     `bh-lex --close`.

Usage:
  bh-lex <<'PY'                 # connectionless: run browser-harness on the cloud browser
  print(page_info())
  PY

  BH_LEX_ISOLATED=1 BU_NAME=job7 bh-lex <<'PY' ... PY   # dedicated browser for parallel use
  BH_LEX_ISOLATED=1 BU_NAME=job7 bh-lex --close          # tear it down

Env:
  BH_LEX_REGION=cn|en           # which Lexmount project (default cn)
  BH_LEX_ISOLATED=1             # use a dedicated session instead of the pooled browser
  BU_NAME=<pool>               # session key in isolated mode (default: bh-lex-<region>)
  LEXMOUNT_API_KEY / _PROJECT_ID / _BASE_URL            (cn creds)
  LEXMOUNT_API_KEY_EN / _PROJECT_ID_EN / _BASE_URL_EN   (en creds)
Creds are read from (low->high precedence): the lexmount-browser skill's .env,
~/.config/browser-harness/lexmount.env, a project .env (repo root then cwd),
then real LEXMOUNT_* env vars. Put them wherever fits; .env is gitignored.
"""
import os, sys, json, subprocess, pathlib, importlib.util
from urllib.parse import urlparse, urlencode, urlunparse

REPO = pathlib.Path(__file__).resolve().parent
SKILL = pathlib.Path.home() / ".claude/skills/lexmount-browser"
STATE_DIR = pathlib.Path(os.environ.get("XDG_CONFIG_HOME", pathlib.Path.home()/".config")) / "browser-harness" / "lex"


def _load_env():
    # Precedence (low -> high): skill .env, config-dir lexmount.env, project .env
    # (repo root then cwd — the dotenv convention), then real env vars.
    env = {}
    sources = [SKILL / ".env", STATE_DIR.parent / "lexmount.env", REPO / ".env", pathlib.Path.cwd() / ".env"]
    seen = set()
    for envfile in sources:
        rp = envfile.resolve()
        if rp in seen or not envfile.is_file():
            continue
        seen.add(rp)
        for line in envfile.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                k, v = line.split("=", 1)
                if k.strip().startswith("LEXMOUNT_"):
                    env[k.strip()] = v.strip().strip('"').strip("'")
    env.update({k: v for k, v in os.environ.items() if k.startswith("LEXMOUNT_")})
    return env


def _creds(region):
    e = _load_env()
    sfx = "_EN" if region == "en" else ""
    key = e.get(f"LEXMOUNT_API_KEY{sfx}") or e.get("LEXMOUNT_API_KEY")
    pid = e.get(f"LEXMOUNT_PROJECT_ID{sfx}") or e.get("LEXMOUNT_PROJECT_ID")
    base = e.get(f"LEXMOUNT_BASE_URL{sfx}") or e.get("LEXMOUNT_BASE_URL")
    if not key or not pid or not base:
        sys.exit(f"bh-lex: missing Lexmount creds for region={region} (LEXMOUNT_API_KEY{sfx}/_PROJECT_ID{sfx}/_BASE_URL{sfx})")
    return key, pid, base


def connectionless_url(region):
    key, pid, base = _creds(region)
    p = urlparse(base)
    scheme = "wss" if p.scheme == "https" else "ws"
    query = urlencode({"project_id": pid, "api_key": key})
    return urlunparse((scheme, p.netloc, "/connection", "", query, ""))


def _sdk():
    for cand in SKILL.glob(".venv/lib/python*/site-packages"):
        sys.path.insert(0, str(cand))
    if importlib.util.find_spec("lexmount") is None:
        sys.exit("bh-lex: lexmount SDK not found — is the lexmount-browser skill installed?")
    import lexmount
    return lexmount


def _client(region):
    key, pid, base = _creds(region)
    return _sdk().Lexmount(api_key=key, project_id=pid, base_url=base)


def _statefile(name):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    return STATE_DIR / f"{name}.json"


def isolated_url(region, name):
    client = _client(region)
    sf = _statefile(name)
    if sf.is_file():
        st = json.loads(sf.read_text())
        try:
            if getattr(client.sessions.get(st["session_id"]), "status", "") == "active":
                client.close()
                return st["connect_url"]
        except Exception:
            pass
    s = client.sessions.create(browser_mode="normal")   # ephemeral: no persistent context
    url = s.connect_url or s.ws
    sf.write_text(json.dumps({"session_id": s.session_id, "connect_url": url}))
    client.close()
    return url


def close_isolated(region, name):
    sf = _statefile(name)
    if not sf.is_file():
        print("bh-lex: no cached session")
        return
    st = json.loads(sf.read_text())
    client = _client(region)
    try:
        client.sessions.delete(session_id=st["session_id"])
        print(f"bh-lex: closed {st['session_id']}")
    except Exception as e:
        print(f"bh-lex: close failed ({e}); clearing cache anyway")
    finally:
        client.close()
        sf.unlink(missing_ok=True)


def main():
    region = os.environ.get("BH_LEX_REGION", "cn").lower()
    isolated = os.environ.get("BH_LEX_ISOLATED") == "1"
    name = os.environ.get("BU_NAME") or f"bh-lex-{region}"
    if "--close" in sys.argv[1:]:
        # Close the isolated session (or, in default mode, any fallback session).
        close_isolated(region, name if isolated else name + "-fb")
        return
    code = sys.stdin.buffer.read()

    def run(url, nm):
        env = {**os.environ, "BU_CDP_WS": url, "BU_NAME": nm}
        return subprocess.run([str(REPO / "browser-harness")], input=code, env=env,
                              stderr=subprocess.PIPE)

    CONN_FAIL = ("WebSocket connection closed", "CDP WS handshake failed", "opening handshake")
    if isolated:
        r = run(isolated_url(region, name), name)
        sys.stderr.buffer.write(r.stderr)
        sys.exit(r.returncode)

    # Default: connectionless pooled browser, with automatic fallback to a fresh
    # ephemeral session if the pooled browser is unreachable.
    r = run(connectionless_url(region), name)
    err = r.stderr.decode("utf-8", "replace")
    if r.returncode != 0 and any(s in err for s in CONN_FAIL):
        print("bh-lex: connectionless browser unreachable; falling back to a fresh session", file=sys.stderr)
        r = run(isolated_url(region, name + "-fb"), name)
    sys.stderr.buffer.write(r.stderr)
    sys.exit(r.returncode)


if __name__ == "__main__":
    main()
